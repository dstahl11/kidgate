# ── KidGate configuration ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── UniFi controller (UDM) ────────────────────────────────────────────
# Host is the UDM's LAN IP or hostname, no scheme, no trailing slash.
UNIFI_HOST=192.168.1.1
# Dedicated LOCAL admin account with firewall-edit rights — NOT superadmin.
UNIFI_USERNAME=kidgate
UNIFI_PASSWORD=change-me
# Site is almost always "default".
UNIFI_SITE=default
# UDM uses a self-signed cert; leave false unless you've installed a trusted cert.
UNIFI_VERIFY_TLS=false

# ── Policy mapping (filled in AFTER the spike identifies the IDs) ──────
ADHOC_BLOCK_POLICY_ID=
SCHEDULED_BLOCK_POLICY_ID=

# ── App ───────────────────────────────────────────────────────────────
TIMEZONE=America/New_York
SECRET_KEY=generate-a-long-random-string
# Bedtime used for the "until bedtime" preset (24h local time).
BEDTIME_HOUR=23
BEDTIME_MINUTE=30
# Local app logins: name:password:role (role = admin|user), comma-separated.
# These are the PORTAL accounts (not UniFi). Change the passwords.
APP_USERS=david:changeme-admin:admin,wife:changeme-user:user

# ── Notifications (ntfy) ──────────────────────────────────────────────
# Leave NTFY_TOPIC blank to disable notifications.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
# Optional auth for self-hosted/protected topics (token preferred).
NTFY_TOKEN=
